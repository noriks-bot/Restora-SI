    var dist_open = null;
    var current_tab = document.querySelector('.tabs')?.getAttribute('data-active');

    function handleChevron() {
        const headerChevron = document.querySelector('.header-chevron');
        if (headerChevron) {
            Array.from(headerChevron.children).forEach(child => {
                if (child.classList.contains('chevron-hide')) child.classList.remove('chevron-hide');
                else child.classList.add('chevron-hide');
            });
        }
    }

    function openDist() {
        const headerChevron = document.querySelector('.header-chevron');
        window.focus();

        const reviewsDist = document.querySelector('.reviews-dist');
        if (reviewsDist) reviewsDist.style.display = 'block';

        if (headerChevron) headerChevron.classList.add('dialog-open');

        const summaryContent = document.querySelector('.summary-content.b');
        if (summaryContent) summaryContent.ariaExpanded = "true";

        dist_open = true;
        handleChevron();

        window.parent.postMessage(JSON.stringify({
            type: 'set-ref-interaction',
            ref: 'loox-header-dist',
            frame: frameId
        }), "*");
    }

    function closeDist() {
        const headerChevron = document.querySelector('.header-chevron');
        if (distributionDropdown) distributionDropdown.classList.add('close-dialog-animation');

        dist_open = null;

        const summaryContent = document.querySelector('.summary-content.b');
        if (summaryContent) summaryContent.ariaExpanded = "true";

        if (headerChevron) {
            headerChevron.classList.remove('dialog-open');
            headerChevron.blur();
        }

        handleChevron();
    }

    addAnimationendEventListener();

    function closeDistributionOnClickOutside(e) {
        if (window.innerWidth <= 480 || !dist_open) {
            return;
        }

        const parentElementWithPanelDist = e.target.closest('[data-panel="dist"]');

        if (!parentElementWithPanelDist) { 
            closeDist();
        }
    }

    function closeDistributionDialogOnEscButton(e) {
        if (e.keyCode != 27) return;

        if (dist_open)
            closeDist();
    };

    function addAnimationendEventListener() {
        distributionDropdown = document.getElementsByClassName('reviews-dist')[0];
        if (distributionDropdown) {
            distributionDropdown.addEventListener('animationend', function () {
                if (distributionDropdown.classList.contains('close-dialog-animation')) {
                    distributionDropdown.classList.remove('close-dialog-animation');

                    const reviewsDist = document.querySelector('.reviews-dist');
                    if (reviewsDist) reviewsDist.style.display = 'none';
                }
            })
        }
    }

    window.addEventListener('click', closeDistributionOnClickOutside);
    window.addEventListener('keyup', closeDistributionDialogOnEscButton);

    document.addEventListener('click', function (e) {
        addAnimationendEventListener();

        const tabEl = e.target.closest('.tabs__tab');
        if(tabEl) {
            const dataTab = tabEl.getAttribute('data-tab');
            if(dataTab !== current_tab) {
                dist_open = null;
                current_tab = dataTab;
            }

            return;
        }
        

        const summaryContent = e.target.closest('.summary-content.b');

        if(!summaryContent || !distributionDropdown) return;

        if(!dist_open) distributionDropdown.classList.remove('close-dialog-animation');

        if(!dist_open) openDist();
        else closeDist();
    });

    document.querySelector('.loox-dropdown.reviews-dist')?.addEventListener('click', function (e) {
        e.stopPropagation();
    });

    window.addEventListener('blur', function () {
        if (window.innerWidth > 480 && dist_open) closeDist();
    })
})()</script><script>(function() {
    var menu_open = null

