<script>
  document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('soyaStoryModal');
    const video = document.getElementById('soyaStoryVideo');

    // ouverture modale
    document.querySelectorAll('.soya-story').forEach(btn => {
      btn.addEventListener('click', () => {
        const src = btn.getAttribute('data-video');
        video.querySelector('source').setAttribute('src', src);
        video.load();
        video.play();
        modal.classList.add('active');
      });
    });

    // fermeture modale
    modal.addEventListener('click', (e) => {
      if (
        e.target.classList.contains('soya-story-overlay') ||
        e.target.closest('.soya-story-close')
      ) {
        video.pause();
        modal.classList.remove('active');
      }
    });

    // MINI-TEASERS 5s
    const thumbs = document.querySelectorAll('.soya-thumb-video');
    thumbs.forEach(v => {
      // certains navigateurs bloquent l'autoplay : on tente
      v.play().then(() => {
        // après 5s on stop et on remet au début
        setTimeout(() => {
          v.pause();
          v.currentTime = 0;
        }, 10000);
      }).catch(() => {
        // si l'autoplay est bloqué on fait rien
      });
    });
  });
</script>
