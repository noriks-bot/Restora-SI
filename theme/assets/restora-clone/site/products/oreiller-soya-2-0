<script>
 if(window.innerWidth < 786){
    const sliderWrapper = document.querySelector('.ev-reviewv2s-data-wrapper');
    const sliderContainer = document.querySelector('.ev-reviewv2s-data-container');
    const allSlides = Array.from(document.querySelectorAll('.ev-reviewv2-data')).filter(
      slide => slide.style.display !== 'none'
    );
    
    let isSwiping = false;
    let startTouchX = 0;
    let currentSlideIndex = 0;
    
    // Function to calculate and set slide width dynamically
    function getSlideWidth() {
      const wrapperWidth = sliderWrapper.offsetWidth; // Full visible width
      return wrapperWidth; // Assuming full width per slide
    }
    
    // Function to move slider
    function updateSliderPosition() {
      const slideWidth = getSlideWidth();
      sliderContainer.style.transform = `translateX(-${currentSlideIndex * slideWidth}px)`; // Fixed the template string here
    }
    
    // Handle swipe events
    sliderWrapper.addEventListener('touchstart', (event) => {
      isSwiping = true;
      startTouchX = event.touches[0].pageX; // Record start position
    });
    
    sliderWrapper.addEventListener('touchend', (event) => {
      if (!isSwiping) return;
      isSwiping = false;
    
      const endTouchX = event.changedTouches[0].pageX;
      const swipeDistance = startTouchX - endTouchX;
    
      if (swipeDistance > 50) {
        // Swipe left
        if (currentSlideIndex < allSlides.length - 1) currentSlideIndex++;
      } else if (swipeDistance < -50) {
        // Swipe right
        if (currentSlideIndex > 0) currentSlideIndex--;
      }
    
      updateSliderPosition();
    });
    
    // Adjust on window resize
    window.addEventListener('resize', updateSliderPosition);
    
    // Initial slide position
    updateSliderPosition();
 }
</script>

